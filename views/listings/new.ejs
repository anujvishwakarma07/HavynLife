<% layout("/layouts/boilerplate") %>

  <div class="row mt-4">
    <div class="col-12 col-md-10 col-lg-8 offset-md-1 offset-lg-2">
      <h2 class="fw-bold mb-4">Host Your Space</h2>
      <div class="form-card">
        <h5 class="mb-4">Enter Listing Details</h5>
        <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
          <div class="mb-4">
            <label for="title" class="form-label">Property Title</label>
            <input name="listing[title]" placeholder="e.g. Modern Beachfront Villa" type="text" class="form-control"
              required />
            <div class="invalid-feedback">A catchy title is required.</div>
          </div>

          <div class="mb-4">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]"
              placeholder="Tell us about the vibes, the view, and what makes it unique..." rows="4" class="form-control"
              required></textarea>
            <div class="invalid-feedback">Please provide a brief description.</div>
          </div>

          <!-- <div class="mb-4">
            <label for="image" class="form-label">Image URL</label>
            <input name="listing[image]" placeholder="Link to a stunning photo" type="text" class="form-control"
            required />
            <div class="invalid-feedback">Don't forget the photo link!</div>
          </div> -->

          <div class="mb-4">
            <label for="image" class="form-label">Upload Listing Image</label>
            <input name="listing[image]" placeholder="Upload Image" type="file" class="form-control" required />
            <div class="invalid-feedback">Don't forget to upload the image!</div>
          </div>

          <div class="row">
            <div class="mb-4 col-md-4">
              <label for="price" class="form-label">Price per night (₹)</label>
              <input type="number" name="listing[price]" placeholder="1500" class="form-control" required />
              <div class="invalid-feedback">Set a fair price for your stay.</div>
            </div>

            <div class="mb-4 col-md-4">
              <label for="country" class="form-label">Country</label>
              <input type="text" name="listing[country]" placeholder="e.g. India" class="form-control" required />
              <div class="invalid-feedback">Country name is required.</div>
            </div>

            <div class="mb-4 col-md-4">
              <label for="category" class="form-label">Category</label>
              <select name="listing[category]" class="form-select form-control" required>
                <option value="" disabled selected>Select a category</option>
                <option value="Trending">Trending</option>
                <option value="Rooms">Rooms</option>
                <option value="Iconic Cities">Iconic Cities</option>
                <option value="Mountains">Mountains</option>
                <option value="Castles">Castles</option>
                <option value="Amazing Pools">Amazing Pools</option>
                <option value="Camping">Camping</option>
                <option value="Farms">Farms</option>
                <option value="Arctic">Arctic</option>
                <option value="Domes">Domes</option>
              </select>
              <div class="invalid-feedback">Please choose a category.</div>
            </div>
          </div>

          <div class="mb-5">
            <label for="location" class="form-label">Specific Location</label>
            <input type="text" name="listing[location]" placeholder="e.g. Anjuna, Goa" class="form-control" required />
            <div class="invalid-feedback">Help guests find you!</div>
          </div>

          <div class="d-flex align-items-center gap-3">
            <button class="submit-btn border-0">Create Listing</button>
            <button type="button" class="cancel-btn align-middle"
              onclick="window.location.href='/listings'">Cancel</button>
          </div>
        </form>
      </div>
    </div>
  </div>