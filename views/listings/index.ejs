<% layout("/layouts/boilerplate") %>

  <style>
    #filters {
      display: flex;
      align-items: center;
      flex-wrap: nowrap;
      padding: 1rem 0;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      white-space: nowrap;
      border-bottom: 1px solid #f0f0f0;
    }

    #filters::-webkit-scrollbar {
      display: none;
    }

    .filter {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      text-align: center;
      margin-right: 2.2rem;
      opacity: 0.6;
      cursor: pointer;
      transition: all 0.2s ease;
      min-width: 52px;
      color: #222;
      text-decoration: none;
    }

    .filter:hover {
      opacity: 1;
    }

    .filter i {
      display: block;
      font-size: 1.35rem;
      margin-bottom: 0.4rem;
    }

    .filter p {
      display: block;
      font-size: 0.8rem;
      margin: 0;
      font-weight: 500;
      white-space: nowrap;
    }

    .active-filter {
      opacity: 1;
      border-bottom: 2px solid #222;
      padding-bottom: 5px;
    }

    .tax-toggle-box {
      border: 1px solid #ddd;
      border-radius: 0.8rem;
      padding: 0.8rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.8rem;
      white-space: nowrap;
      margin-left: auto;
      background-color: #fff;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
      cursor: pointer;
    }

    .tax-toggle-box:hover {
      background-color: #f7f7f7;
      border-color: #ccc;
    }

    .tax-info {
      display: none;
      font-size: 0.85rem;
      color: #717171;
      font-weight: 400;
    }


    .form-switch .form-check-input {
      width: 2.5em;
      height: 1.25em;
      cursor: pointer;
    }

    .form-switch .form-check-input:checked {
      background-color: #222;
      border-color: #222;
    }
  </style>

  <div id="filters" class="mb-4">
    <a href="/listings?category=Trending" class="filter <%= currentCategory === 'Trending' ? 'active-filter' : '' %>">
      <i class="fa-solid fa-fire"></i>
      <p>Trending</p>
    </a>
    <a href="/listings?category=Rooms" class="filter <%= currentCategory === 'Rooms' ? 'active-filter' : '' %>">
      <i class="fa-solid fa-bed"></i>
      <p>Rooms</p>
    </a>
    <a href="/listings?category=Iconic Cities"
      class="filter <%= currentCategory === 'Iconic Cities' ? 'active-filter' : '' %>">
      <i class="fa-solid fa-mountain-city"></i>
      <p>Iconic Cities</p>
    </a>
    <a href="/listings?category=Mountains" class="filter <%= currentCategory === 'Mountains' ? 'active-filter' : '' %>">
      <i class="fa-solid fa-mountain"></i>
      <p>Mountains</p>
    </a>
    <a href="/listings?category=Castles" class="filter <%= currentCategory === 'Castles' ? 'active-filter' : '' %>">
      <i class="fa-brands fa-fort-awesome"></i>
      <p>Castles</p>
    </a>
    <a href="/listings?category=Amazing Pools"
      class="filter <%= currentCategory === 'Amazing Pools' ? 'active-filter' : '' %>">
      <i class="fa-solid fa-person-swimming"></i>
      <p>Amazing Pools</p>
    </a>
    <a href="/listings?category=Camping" class="filter <%= currentCategory === 'Camping' ? 'active-filter' : '' %>">
      <i class="fa-solid fa-campground"></i>
      <p>Camping</p>
    </a>
    <a href="/listings?category=Farms" class="filter <%= currentCategory === 'Farms' ? 'active-filter' : '' %>">
      <i class="fa-solid fa-tractor"></i>
      <p>Farms</p>
    </a>
    <a href="/listings?category=Arctic" class="filter <%= currentCategory === 'Arctic' ? 'active-filter' : '' %>">
      <i class="fa-regular fa-snowflake"></i>
      <p>Arctic</p>
    </a>
    <a href="/listings?category=Domes" class="filter <%= currentCategory === 'Domes' ? 'active-filter' : '' %>">
      <i class="fa-solid fa-igloo"></i>
      <p>Domes</p>
    </a>

    <div class="tax-toggle-box">
      <span class="fw-bold" style="font-size: 0.9rem;">Display total before taxes</span>
      <div class="form-check form-switch m-0">
        <input class="form-check-input shadow-none" type="checkbox" role="switch" id="taxSwitch">
      </div>
    </div>
  </div>

  <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 row-cols-1 mt-3">
    <% if(searchQuery) { %>
      <div class="col-12 mb-4">
        <h3 class="fw-bold">Search results for "<%= searchQuery %>"</h3>
      </div>
      <% } %>

        <% if(allListings.length===0) { %>
          <div class="col-12 mt-5 text-center">
            <% if(searchQuery) { %>
              <h4 class="text-muted">No exact matches found for "<%= searchQuery %>".</h4>
              <p class="text-muted mt-2">Try changing or removing some of your filters or search terms.</p>
              <% } else { %>
                <h4 class="text-muted">No listings found for this category yet.</h4>
                <% } %>
                  <a href="/listings" class="btn btn-outline-dark mt-3 rounded-pill fw-bold px-4">View All Listings</a>
          </div>
          <% } %>

            <% for (let listing of allListings) { %>
              <a href="/listings/<%= listing._id %>" class="listing-link">
                <div class="card col listing-card">
                  <img src="<%= listing.image.url %>" class="card-img-top" alt="listing-image" />
                  <div class="card-img-overlay"></div>
                  <div class="card-body">
                    <div class="listing-title">
                      <%= listing.title %>
                    </div>
                    <div class="listing-card-text text-muted mb-1">
                      <%= listing.location %>, <%= listing.country %>
                    </div>
                    <div class="listing-price fw-bold">
                      &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %> <span
                          class="fw-light text-muted ms-1">night</span>
                        <div class="tax-info mt-1"><i class="fa-solid fa-plus text-muted"
                            style="font-size: 0.6rem;"></i>
                          18%
                          GST</div>
                    </div>
                  </div>
                </div>
              </a>
              <% } %>
  </div>

  <script>
    document.getElementById("taxSwitch").addEventListener("change", function () {
      let taxInfoElements = document.getElementsByClassName("tax-info");
      for (let info of taxInfoElements) {
        if (this.checked) {
          info.style.display = "block";
        } else {
          info.style.display = "none";
        }
      }
    });
  </script>