<% layout("/layouts/boilerplate") %>

  <div class="show-container">
    <div class="row">
      <div class="col-12 px-0">
        <h2 class="show-title">
          <%= listing.title %>
        </h2>
      </div>

      <div class="col-12 px-0">
        <div class="show-img-container">
          <img src="<%= listing.image.url %>" class="show-img" alt="listing_image" />
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <div class="col-12 col-md-8 pe-md-5">
        <div class="listing-owner-info">
          <div class="owner-avatar">
            <%= listing.owner.username.charAt(0).toUpperCase() %>
          </div>
          <div class="owner-text">
            <h5>Entire home hosted by <%= listing.owner.username %>
            </h5>
            <p>Professional Host • 2 years experience</p>
          </div>
        </div>

        <div class="listing-description">
          <%= listing.description %>
        </div>

        <div class="listing-meta">
          <div class="listing-meta-item">
            <i class="fa-solid fa-location-dot"></i>
            <span>
              <%= listing.location %>, <%= listing.country %>
            </span>
          </div>
          <div class="listing-meta-item mb-2">
            <i class="fa-solid fa-layer-group"></i>
            <span class="fw-bold" style="color: #ff385c;">
              <%= listing.category || "General" %>
            </span>
          </div>
          <div class="listing-meta-item">
            <i class="fa-solid fa-door-open"></i>
            <span>Self check-in with smart lock</span>
          </div>
          <div class="listing-meta-item">
            <i class="fa-solid fa-calendar-check"></i>
            <span>Free cancellation for 48 hours</span>
          </div>
        </div>

        <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
          <div class="show-btns-container">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-show-edit">
              Edit
            </a>
            <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
              <button class="btn btn-show-delete">Delete</button>
            </form>
          </div>
          <% } %>
      </div>

      <div class="col-12 col-md-4 mt-4 mt-md-0">
        <div class="card shadow-sm rounded-4 p-4 border sticky-top" style="top: 100px; z-index: 10;">
          <div class="price-tag mb-3">
            &#8377; <%= (listing.price ?? 0).toLocaleString("en-IN") %> <span>/ night</span>
          </div>
          <button class="btn btn-danger w-100 rounded-3 py-2 fw-bold" disabled>Reserve</button>
          <p class="text-center text-muted small mt-2">You won't be charged yet</p>
          <hr>
          <div class="d-flex justify-content-between mb-2">
            <span class="text-decoration-underline">Total before taxes</span>
            <span class="fw-bold">&#8377; <%= (listing.price ?? 0).toLocaleString("en-IN") %></span>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 reviews-section mt-5 px-0">
      <% if(currUser) { %>
        <div class="review-form-card mb-5">
          <h4 class="mb-4">Leave a review</h4>
          <form action="/listings/<%= listing._id %>/reviews" method="post" class="needs-validation" novalidate>
            <div class="mb-4">
              <label class="form-label d-block" for="rating">Rating</label>
              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0"
                  aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" checked />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>
            </div>

            <div class="mb-4">
              <label for="comment" class="form-label">Comments</label>
              <textarea name="review[comment]" id="comment" rows="4" class="form-control"
                placeholder="What was it like to stay here?" required></textarea>
              <div class="invalid-feedback">Please share your experience.</div>
            </div>

            <button class="btn btn-auth-submit w-auto px-5">Submit Review</button>
          </form>
        </div>
        <% } %>

          <% if(listing.reviews.length> 0) { %>
            <div class="row align-items-center mb-5">
              <div class="col-auto">
                <h5 class="mb-0 fs-4"><b>All Reviews</b></h5>
              </div>
              <div class="col">
                <hr class="m-0">
              </div>
            </div>

            <div class="row px-2">
              <% for (review of listing.reviews) { %>
                <div class="col-md-6 mb-4">
                  <div class="card review-card h-100 p-2">
                    <div class="card-body">
                      <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="d-flex align-items-center gap-2">
                          <div class="bg-light rounded-circle d-flex align-items-center justify-content-center"
                            style="width:40px; height:40px;">
                            <i class="fa-solid fa-user text-secondary"></i>
                          </div>
                          <div>
                            <h6 class="review-author mb-0">@<%= review.author.username %>
                            </h6>
                            <span class="review-date">
                              <%= new Date(review.createdAt).toLocaleDateString('en-IN', { day: 'numeric' ,
                                month: 'short' , year: 'numeric' }) %>
                            </span>
                          </div>
                        </div>
                        <% if(currUser && currUser._id.equals(review.author._id)) { %>
                          <form method="post"
                            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button class="review-delete-btn"><i class="fa-solid fa-trash-can"></i></button>
                          </form>
                          <% } %>
                      </div>
                      <p class="starability-result mb-3" data-rating="<%= review.rating %>">
                        Rated: <%= review.rating %> stars
                      </p>
                      <p class="review-comment">
                        <%= review.comment %>
                      </p>
                    </div>
                  </div>
                </div>
                <% } %>
            </div>
            <% } %>
              <div class="col-12 mb-5 px-0">
                <h4 class="mb-4">Where you'll be</h4>
                <div id="map"
                  style="height: 400px; width: 100%; border-radius: 1.5rem; border: 1px solid #ddd; box-shadow: 0 4px 15px rgba(0,0,0,0.08);">
                </div>
              </div>
              <style>
                .custom-map-popup .mapboxgl-popup-content {
                  border-radius: 12px;
                  padding: 8px 12px;
                  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
                  border: 1px solid #eaeaea;
                }

                .custom-popup-body {
                  text-align: center;
                  min-width: 120px;
                }

                .custom-popup-body h5 {
                  color: #ff385c;
                  font-weight: 700;
                  margin: 0 0 2px 0;
                  font-size: 0.95rem;
                }

                .custom-popup-body p {
                  margin: 0;
                  font-size: 0.75rem;
                  color: #777;
                  font-weight: 500;
                }
              </style>

              <script>
                const mapToken = "<%= mapToken %>";
                const coordinates = JSON.parse("<%= JSON.stringify(listing.geometry && listing.geometry.coordinates && listing.geometry.coordinates.length == 2 ? listing.geometry.coordinates : [77.209, 28.6139]) %>");
                const listingLocation = "<%= listing.location %>";

                mapboxgl.accessToken = mapToken;

                try {
                  const map = new mapboxgl.Map({
                    container: 'map',
                    style: 'mapbox://styles/mapbox/streets-v12',
                    center: coordinates,
                    zoom: 9
                  });

                  map.addControl(new mapboxgl.NavigationControl());

                  const popup = new mapboxgl.Popup({
                    offset: 25,
                    closeButton: false,
                    closeOnClick: false,
                    className: 'custom-map-popup'
                  })
                    .setHTML(`
                    <div class="custom-popup-body">
                      <h5>${listingLocation}</h5>
                      <p>Exact location provided after booking</p>
                    </div>
                  `);

                  const marker = new mapboxgl.Marker({ color: '#ff385c' })
                    .setLngLat(coordinates)
                    .addTo(map);

                  const markerElement = marker.getElement();
                  markerElement.style.cursor = 'pointer';

                  markerElement.addEventListener('mouseenter', () => {
                    popup.setLngLat(coordinates).addTo(map);
                  });

                  markerElement.addEventListener('mouseleave', () => {
                    popup.remove();
                  });

                  console.log("Map successfully initialized at:", coordinates);
                } catch (err) {
                  console.error("Mapbox error:", err);
                }
              </script>
    </div>
  </div>